# ============================================
# CarSensor Platform - Example Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ------------------------------
# Database Configuration
# ------------------------------
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5433
AUTH_DB_NAME=auth_db
AUTH_DB_USERNAME=postgres
AUTH_DB_PASSWORD=your_password_here

CAR_DB_HOST=localhost
CAR_DB_PORT=5434
CAR_DB_NAME=car_db
CAR_DB_USERNAME=postgres
CAR_DB_PASSWORD=your_password_here

# ------------------------------
# JWT Configuration
# ------------------------------
JWT_SECRET=your-256-bit-secret-key-here-change-in-production
JWT_ACCESS_TOKEN_EXPIRATION=900
JWT_REFRESH_TOKEN_EXPIRATION=604800

# ------------------------------
# Service URLs
# ------------------------------
AUTH_SERVICE_URL=http://auth-service:8081
CAR_SERVICE_URL=http://car-service:8082
SCHEDULER_SERVICE_URL=http://scheduler-service:8083
GATEWAY_SERVICE_URL=http://gateway-service:8080

# ------------------------------
# Frontend Configuration
# ------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------
# Parser Configuration
# ------------------------------
PARSER_MAX_PAGES=5
PARSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
PARSER_TIMEOUT=30000
